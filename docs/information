```json
{
  "programs": [
    {
      "id": "asspe1689",
      "name": "Computer Science Specialist",
      "type": "specialist",
      "code": "ASSPE1689",
      "total_fce": 12.0,
      "is_focus": false,
      "focus_name": null,
      "course_codes": ["CSC110Y1", "CSC111H1", ...],
      "year_groups": {
        "first_year": {
          "fce": 2.5,
          "courses": ["CSC110Y1", "CSC111H1", "MAT137Y1", ...]
        },
        "second_year": {
          "fce": 3.5,
          "courses": ["CSC207H1", "CSC236H1", ...]
        },
        "later_years": {
          "fce": 6.0,
          "courses": ["CSC369H1", "CSC373H1", ...]
        }
      },
      "source_url": "https://artsci.calendar.utoronto.ca/program/asspe1689"
    }
  ],
  "courses": {
    "CSC110Y1": {
      "code": "CSC110Y1",
      "programs": ["asspe1689", "asmaj1689"],
